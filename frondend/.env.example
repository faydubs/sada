# عنوان الـ backend. اتركه فارغاً لاستخدام proxy الخاص بـ Vite أثناء التطوير
# (موصى به محلياً). للإنتاج ضع العنوان الكامل، مثال:
# VITE_API_BASE=https://api.example.com
VITE_API_BASE=

# عنوان WebSocket. اتركه فارغاً ليُشتق تلقائياً من موقع الصفحة عبر proxy.
# للإنتاج: wss://api.example.com
VITE_WS_BASE=
