DATABASE_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
SECRET_KEY=change-this-secret
ALGORITHM=HS256

# CORS: قائمة مصادر مسموحة مفصولة بفاصلة. لا تستخدم "*" في الإنتاج.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional: enable Gemini extraction (المسار الفعلي المُفعَّل حالياً في agent/gemini_parser.py)
GEMINI_API_KEY=

# Optional: enable Allam extraction when API details are ready (غير موصول بالكود حالياً — TODO).
ALLAM_API_URL=
ALLAM_API_KEY=
ALLAM_MODEL=allam
